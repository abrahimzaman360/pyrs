def abs_int(x: int) -> int:
    if x < 0:
        return -x;
    return x;

def min_int(a: int, b: int) -> int:
    if a < b:
        return a;
    return b;

def max_int(a: int, b: int) -> int:
    if a > b:
        return a;
    return b;

def clamp_int(x: int, low: int, high: int) -> int:
    if x < low:
        return low;
    if x > high:
        return high;
    return x;
